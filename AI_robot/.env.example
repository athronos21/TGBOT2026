# Multi-Robot Trading System Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# MetaTrader 5 Configuration
MT5_PASSWORD=your_mt5_password_here
MT5_ACCOUNT=0
MT5_SERVER=ICMarketsSC-Demo

# Database Configuration
DB_USER=trading_user
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_system

# MongoDB Configuration
MONGO_USER=trading_user
MONGO_PASSWORD=your_mongo_password_here
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=trading_logs

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# System Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Optional: API Keys for additional features (Phase 2+)
# TWITTER_API_KEY=your_twitter_api_key
# TWITTER_API_SECRET=your_twitter_api_secret
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# NEWS_API_KEY=your_news_api_key
