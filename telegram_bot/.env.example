# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Supabase (preferred) — get from: Supabase Dashboard → Project → Settings → Database → Connection string
# Use the "Transaction pooler" URI (port 6543) for serverless/short-lived connections
SUPABASE_DB_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Local PostgreSQL fallback (used only if SUPABASE_DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itsmb
DB_USER=postgres
DB_PASSWORD=your_password_here

# App
DEBUG=false
